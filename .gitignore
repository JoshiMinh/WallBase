# Custom Ignore Rules
# Ignore all folders starting with '.' except '.github'
.*
!.github/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# Flutter/Dart related
**/doc/api/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# IDEs
.idea/
*.iml
*.ipr
*.iws

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated files
analysis_output.txt
analysis_results.txt
build_output*.txt
